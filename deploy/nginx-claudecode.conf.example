# Archivo en el repo: deploy/nginx-claudecode.conf.example
# Patrón alineado con otros sitios (ej. complex): HTTP→HTTPS + bloque SSL separado.
#
# En el servidor:
#   sudo cp .../deploy/nginx-claudecode.conf.example /etc/nginx/sites-available/claudecode
#   sudo nano /etc/nginx/sites-available/claudecode   # dominio y rutas cert si cambian
#   sudo ln -sf /etc/nginx/sites-available/claudecode /etc/nginx/sites-enabled/
#   sudo certbot --nginx -d ia.ulpik.com   # si aún no hay certificado
#   sudo nginx -t && sudo systemctl reload nginx

# HTTP → HTTPS (mismo criterio que complex.ulpik.com)
server {
    listen 80;
    listen [::]:80;
    server_name ia.ulpik.com;

    if ($host = ia.ulpik.com) {
        return 301 https://$host$request_uri;
    }

    return 404;
}

# HTTPS — estático (index.html, css/, landing/)
server {
    listen 443 ssl;
    listen [::]:443 ssl ipv6only=on;
    server_name ia.ulpik.com;

    ssl_certificate     /etc/letsencrypt/live/ia.ulpik.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/ia.ulpik.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    root /var/www/html/claudecode;
    index index.html;

    access_log /var/log/nginx/claudecode.access.log;
    error_log  /var/log/nginx/claudecode.error.log;

    gzip on;
    gzip_types text/css application/javascript application/json text/plain text/xml;
    gzip_min_length 256;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location ~* \.(css|js|woff2?|ico|svg)$ {
        expires 7d;
        add_header Cache-Control "public, immutable";
    }

    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
}
