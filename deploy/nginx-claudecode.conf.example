# Archivo en el repo: deploy/nginx-claudecode.conf.example
#
# En el servidor (ajusta dominio en server_name):
#   sudo cp /var/www/html/claudecode/deploy/nginx-claudecode.conf.example /etc/nginx/sites-available/claudecode
#   sudo nano /etc/nginx/sites-available/claudecode   # server_name
#   sudo ln -sf /etc/nginx/sites-available/claudecode /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    listen [::]:80;
    server_name tu-dominio.com www.tu-dominio.com;

    # Raíz del sitio (index.html, css/, landing/)
    root /var/www/html/claudecode;
    index index.html;

    # Logs (opcional)
    access_log /var/log/nginx/claudecode.access.log;
    error_log  /var/log/nginx/claudecode.error.log;

    gzip on;
    gzip_types text/css application/javascript application/json text/plain text/xml;
    gzip_min_length 256;

    location / {
        try_files $uri $uri/ =404;
    }

    # Caché ligera para assets estáticos
    location ~* \.(css|js|woff2?|ico|svg)$ {
        expires 7d;
        add_header Cache-Control "public, immutable";
    }

    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
}

# Tras certificar con Let's Encrypt, Certbot suele añadir un bloque server :443.
